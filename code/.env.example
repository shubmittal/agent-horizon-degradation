# Copy this file to `.env` and paste your OpenRouter key.
# Get one at https://openrouter.ai/keys  (prepaid -> cannot overspend).
OPENROUTER_API_KEY=sk-or-paste-your-key-here

# Optional: OpenRouter attribution headers (harmless to leave as-is).
OPENROUTER_APP_TITLE=agent-rot-study
OPENROUTER_APP_URL=https://github.com/local/agent-rot
